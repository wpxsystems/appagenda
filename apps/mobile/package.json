{
  "name": "@racket-app/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:android:prod": "eas build --profile production --platform android",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:prod": "eas build --profile production --platform ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo-google-fonts/archivo": "^0.4.1",
    "@expo-google-fonts/bricolage-grotesque": "^0.4.1",
    "@expo/metro-runtime": "~3.2.3",
    "@expo/vector-icons": "^14.0.0",
    "expo-linear-gradient": "~13.0.2",
    "@racket-app/shared": "workspace:*",
    "@racket-app/ui": "workspace:*",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3",
    "vitest": "^2.0.0"
  }
}
