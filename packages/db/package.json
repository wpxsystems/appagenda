    "seed": "tsx src/seed.ts"
  },
  "devDependencies": {
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@racket-app/shared": "workspace:*",
    "drizzle-orm": "^0.33.0",
    "pg": "^8.12.0",
    "postgres": "^3.4.0"
  }
